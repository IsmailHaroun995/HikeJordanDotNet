@page
@model AdminModel
@{
    ViewData["Title"] = "Admin dashboard";
}

<section class="admin-hero">
    <div class="container-fluid page-shell admin-hero-grid">
        <div>
            <span class="eyebrow">Administrator workspace</span>
            <h1>Moderate hikes, organizers, reviews, and marketplace quality.</h1>
            <p>
                This dashboard is the control room for the MVP: approve trip supply,
                verify organizer trust signals, watch WhatsApp conversion, and keep reviews clean.
            </p>
        </div>
        <div class="admin-actions">
            <a class="btn primary-action" asp-page="/AddHike">Add test hike</a>
            <a class="btn secondary-action" href="#moderation">Review queue</a>
        </div>
    </div>
</section>

<section class="admin-shell">
    <div class="container-fluid page-shell">
        <div class="admin-kpis" aria-label="Admin metrics">
            <article>
                <span>Organizer requests</span>
                <strong data-counter="organizer-requests">@Model.OrganizerRequests.Count</strong>
                <small>Approve accounts before they can add hikes</small>
            </article>
            <article>
                <span>Submitted hikes</span>
                <strong data-counter="hike-requests">@Model.SubmittedHikes.Count</strong>
                <small>Approve listings before publishing</small>
            </article>
            <article>
                <span>Review flags</span>
                <strong data-counter="review-flags">@Model.ReviewFlags.Count</strong>
                <small>1 high priority item</small>
            </article>
            <article>
                <span>WhatsApp clicks</span>
                <strong>318</strong>
                <small>+24% this week</small>
            </article>
        </div>

        <div class="admin-layout">
            <aside class="admin-sidebar" aria-label="Admin sections">
                <a href="#organizer-requests">Organizer requests</a>
                <a href="#moderation">Trip moderation</a>
                <a href="#organizer-accounts">Organizer accounts</a>
                <a href="#organizer-checks">Organizer verification</a>
                <a href="#trip-reviews">Trip reviews</a>
                <a href="#review-flags">Review flags</a>
                <a href="#destinations">Destinations</a>
                <a href="#analytics">Analytics</a>
                <a href="#settings">Marketplace settings</a>
            </aside>

            <div class="admin-panels">
                <section id="organizer-requests" class="admin-panel priority-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Account approvals</span>
                            <h2>Organizer form requests</h2>
                            <p>New organizers must be approved here before they can sign in and submit hikes.</p>
                        </div>
                    </div>

                    <div class="request-grid">
                        @foreach (var request in Model.OrganizerRequests)
                        {
                            <article class="request-card" data-admin-item="organizer">
                                <div class="request-card-header">
                                    <div class="request-card-identity">
                                        <div class="request-avatar" aria-hidden="true">@(request.Name.Length > 0 ? request.Name[0].ToString().ToUpper() : "?")</div>
                                        <div>
                                            <strong>@request.Name</strong>
                                            <div class="request-contact">
                                                <span class="contact-chip">✉ @request.Email</span>
                                                <span class="contact-chip">📱 @request.WhatsApp</span>
                                            </div>
                                        </div>
                                    </div>
                                    <span class="status-badge status-submitted" data-status>@request.Status</span>
                                </div>
                                <dl class="request-details">
                                    <div>
                                        <dt>Regions</dt>
                                        <dd>@request.Regions</dd>
                                    </div>
                                    <div>
                                        <dt>Experience</dt>
                                        <dd>@request.Experience</dd>
                                    </div>
                                </dl>
                                <div class="approval-actions">
                                    <form method="post" asp-page-handler="UpdateOrganizerRequest" asp-route-id="@request.Id" asp-route-status="Approved">
                                        <button type="submit" data-action="approve-organizer">Approve organizer</button>
                                    </form>
                                    <form method="post" asp-page-handler="UpdateOrganizerRequest" asp-route-id="@request.Id" asp-route-status="Rejected">
                                        <button type="submit" data-action="reject-organizer">Reject</button>
                                    </form>
                                    <form method="post" asp-page-handler="UpdateOrganizerRequest" asp-route-id="@request.Id" asp-route-status="Docs requested">
                                        <button type="submit" data-action="request-docs">Request docs</button>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="moderation" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Trip lifecycle</span>
                            <h2>Submitted hike queue</h2>
                            <p>Approve a hike to move it from Submitted into Approved. Publishing would make it visible to visitors.</p>
                        </div>
                        <div class="status-tabs" aria-label="Moderation filters">
                            <button type="button">Draft</button>
                            <button type="button" class="is-active">Submitted</button>
                            <button type="button">Approved</button>
                            <button type="button">Published</button>
                            <button type="button">Archived</button>
                        </div>
                    </div>

                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Hike</th>
                                    <th>Organizer</th>
                                    <th>Region</th>
                                    <th>Level</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hike in Model.SubmittedHikes)
                                {
                                    <tr data-admin-item="hike">
                                        <td>
                                            <strong>@hike.Title</strong>
                                            <span>@hike.Note</span>
                                        </td>
                                        <td>@hike.Organizer</td>
                                        <td>@hike.Region</td>
                                        <td>@hike.Difficulty</td>
                                        <td>@hike.DateLabel</td>
                                        <td><span class="status-badge status-submitted" data-status>@hike.Status</span></td>
                                        <td>
                                            <div class="table-actions">
                                                <form method="post" asp-page-handler="UpdateHike" asp-route-id="@hike.Id" asp-route-status="Approved">
                                                    <button type="submit" data-action="approve-hike">Approve</button>
                                                </form>
                                                <form method="post" asp-page-handler="UpdateHike" asp-route-id="@hike.Id" asp-route-status="Hidden">
                                                    <button type="submit" data-action="hide-hike">Hide</button>
                                                </form>
                                                <form method="post" asp-page-handler="UpdateHike" asp-route-id="@hike.Id" asp-route-status="Rejected">
                                                    <button type="submit" data-action="reject-hike">Reject</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section id="organizer-accounts" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Account management</span>
                            <h2>Organizer accounts</h2>
                            <p>Disable an organizer to block login and prevent new hike submissions. Re-enable to restore access.</p>
                        </div>
                    </div>
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Organizer</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var organizer in Model.ActiveOrganizers)
                                {
                                    <tr>
                                        <td>
                                            <div class="table-identity">
                                                <div class="table-avatar" aria-hidden="true">@(organizer.Name.Length > 0 ? organizer.Name[0].ToString().ToUpper() : "?")</div>
                                                <strong>@organizer.Name</strong>
                                            </div>
                                        </td>
                                        <td><span class="table-email">@organizer.Email</span></td>
                                        <td><span class="role-chip">@organizer.Role</span></td>
                                        <td>
                                            <span class="status-badge @(organizer.ApprovalStatus == "Disabled" ? "status-rejected" : "status-approved")" data-status>
                                                @organizer.ApprovalStatus
                                            </span>
                                        </td>
                                        <td>
                                            <div class="table-actions">
                                                @if (organizer.ApprovalStatus == "Disabled")
                                                {
                                                    <form method="post" asp-page-handler="EnableOrganizer" asp-route-id="@organizer.Id">
                                                        <button type="submit" data-action="enable-organizer">Enable</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form method="post" asp-page-handler="DisableOrganizer" asp-route-id="@organizer.Id">
                                                        <button type="submit" data-action="disable-organizer">Disable</button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section id="organizer-checks" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Trust operations</span>
                            <h2>Organizer verification</h2>
                        </div>
                    </div>
                    <div class="verification-grid">
                        @foreach (var organizer in Model.OrganizerReviews)
                        {
                            <article class="verification-card">
                                <div>
                                    <strong>@organizer.Name</strong>
                                    <span>@organizer.Rating rating · @organizer.PastTrips</span>
                                </div>
                                <span class="status-badge">@organizer.Status</span>
                                <p>@organizer.Note</p>
                                <div class="table-actions">
                                    <form method="post" asp-page-handler="UpdateOrganizerProfile" asp-route-id="@organizer.Id" asp-route-status="Verified">
                                        <button type="submit" data-action="verify-card">Verify</button>
                                    </form>
                                    <form method="post" asp-page-handler="UpdateOrganizerProfile" asp-route-id="@organizer.Id" asp-route-status="Docs requested">
                                        <button type="submit" data-action="request-docs-card">Request docs</button>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="trip-reviews" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Joiner reviews</span>
                            <h2>Pending trip reviews</h2>
                            <p>Reviews are submitted by trip joiners and held here until approved. Approve to publish on the trip card, reject to discard.</p>
                        </div>
                    </div>
                    @if (!Model.PendingReviews.Any())
                    {
                        <p class="muted-note">No pending reviews.</p>
                    }
                    else
                    {
                        <div class="flag-list">
                            @foreach (var review in Model.PendingReviews)
                            {
                                <article>
                                    <div>
                                        <strong>@review.ReviewerName — @string.Concat(Enumerable.Repeat("★", review.Rating))@string.Concat(Enumerable.Repeat("☆", 5 - review.Rating))</strong>
                                        <span class="muted-note">@review.Hike?.Title · @review.CreatedAtUtc.ToString("MMM d")</span>
                                        <p>@review.ReviewText</p>
                                    </div>
                                    <div class="table-actions">
                                        <form method="post" asp-page-handler="ApproveReview" asp-route-id="@review.Id">
                                            <button type="submit" data-action="approve-review">Approve</button>
                                        </form>
                                        <form method="post" asp-page-handler="RejectReview" asp-route-id="@review.Id">
                                            <button type="submit" data-action="reject-review">Reject</button>
                                        </form>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>

                <section id="review-flags" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Review system</span>
                            <h2>Moderation flags</h2>
                        </div>
                    </div>
                    <div class="flag-list">
                        @foreach (var flag in Model.ReviewFlags)
                        {
                            <article>
                                <span class="priority">@flag.Priority</span>
                                <div>
                                    <strong>@flag.Title</strong>
                                    <p>@flag.Detail</p>
                                </div>
                                <form method="post" asp-page-handler="ResolveFlag" asp-route-id="@flag.Id">
                                    <button type="submit" data-action="resolve-flag">Resolve</button>
                                </form>
                            </article>
                        }
                    </div>
                </section>

                <section id="destinations" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Marketplace configuration</span>
                            <h2>Destinations</h2>
                            <p>Manage the regions organizers can choose when submitting trips. Active destinations also appear in the homepage filter.</p>
                        </div>
                    </div>

                    <form method="post" asp-page-handler="AddDestination" class="destination-add-form">
                        <div class="dest-add-fields">
                            <div>
                                <label for="destName">Name</label>
                                <input id="destName" name="name" class="form-control" placeholder="e.g. Petra" required maxlength="80" />
                            </div>
                            <div>
                                <label for="destImage">Cover image URL <small>(optional)</small></label>
                                <input id="destImage" name="coverImageUrl" class="form-control" placeholder="https://..." maxlength="400" />
                            </div>
                        </div>
                        <button type="submit" class="btn primary-action">Add destination</button>
                    </form>

                    <div class="destination-manage-grid">
                        @foreach (var dest in Model.Destinations)
                        {
                            <article class="destination-manage-card">
                                @if (!string.IsNullOrEmpty(dest.CoverImageUrl))
                                {
                                    <div class="dest-thumb" style="background-image:url('@dest.CoverImageUrl')"></div>
                                }
                                <div class="dest-info">
                                    <strong>@dest.Name</strong>
                                    <span class="status-badge @(dest.IsActive ? "status-approved" : "status-rejected")">
                                        @(dest.IsActive ? "Active" : "Disabled")
                                    </span>
                                </div>
                                <div class="table-actions">
                                    <form method="post" asp-page-handler="ToggleDestination" asp-route-id="@dest.Id">
                                        <button type="submit">@(dest.IsActive ? "Disable" : "Enable")</button>
                                    </form>
                                    <form method="post" asp-page-handler="DeleteDestination" asp-route-id="@dest.Id"
                                          onsubmit="return confirm('Delete @dest.Name? This cannot be undone.')">
                                        <button type="submit" data-action="reject-hike">Delete</button>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section id="analytics" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Marketplace analytics</span>
                            <h2>What admins should track</h2>
                        </div>
                    </div>
                    <div class="analytics-grid">
                        <article><strong>Search-to-click rate</strong><span>Measures whether users find a hike quickly.</span></article>
                        <article><strong>Organizer response rate</strong><span>Protects trust when booking happens in WhatsApp.</span></article>
                        <article><strong>Approval time</strong><span>Keeps new supply from getting stuck in Submitted.</span></article>
                        <article><strong>Flag rate</strong><span>Shows review quality and fake-review risk.</span></article>
                    </div>
                </section>

                <section id="settings" class="admin-panel">
                    <div class="panel-heading">
                        <div>
                            <span class="eyebrow">Configuration</span>
                            <h2>Marketplace settings</h2>
                            <p>These controls govern how the platform behaves for organizers and visitors.</p>
                        </div>
                    </div>

                    <div class="settings-sections">

                        <div class="settings-group">
                            <h3 class="settings-group-title">Marketplace operations</h3>
                            <div class="settings-toggle-list">
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Site is live</strong>
                                        <span>Uncheck to put the site into maintenance mode — visitors see a holding page.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Accept new organizer signups</strong>
                                        <span>Disable to stop new organizers from submitting the signup form.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Allow trip submissions</strong>
                                        <span>Disable to freeze all new hike submissions from approved organizers.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Trip reviews enabled</strong>
                                        <span>Disable to hide the review form and all joiner reviews site-wide.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                            </div>
                        </div>

                        <div class="settings-group">
                            <h3 class="settings-group-title">Trip requirements</h3>
                            <div class="settings-toggle-list">
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Require admin approval before publishing</strong>
                                        <span>Submitted hikes must be approved here before they go live.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>WhatsApp number required on every hike</strong>
                                        <span>Organizers cannot submit a trip without a valid WhatsApp contact.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Verified reviews only</strong>
                                        <span>Only reviews from verified joiners count toward the public rating.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" checked />
                                </label>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Enable paid featured placements</strong>
                                        <span>Allow organizers to pay for highlighted placement on the homepage.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" />
                                </label>
                            </div>
                        </div>

                        <div class="settings-group">
                            <h3 class="settings-group-title">Limits</h3>
                            <div class="settings-field-list">
                                <div class="settings-field-row">
                                    <label for="settingMaxSpots">
                                        <strong>Default max spots per trip</strong>
                                        <span>Organizers can override this per trip, but this is the starting value.</span>
                                    </label>
                                    <input id="settingMaxSpots" type="number" class="settings-input" value="20" min="1" max="500" />
                                </div>
                                <div class="settings-field-row">
                                    <label for="settingMaxTrips">
                                        <strong>Max active trips per organizer</strong>
                                        <span>Prevents one organizer from flooding the marketplace.</span>
                                    </label>
                                    <input id="settingMaxTrips" type="number" class="settings-input" value="10" min="1" max="100" />
                                </div>
                                <div class="settings-field-row">
                                    <label for="settingMinRating">
                                        <strong>Minimum stars to display review</strong>
                                        <span>Reviews below this rating are held for admin review before publishing.</span>
                                    </label>
                                    <input id="settingMinRating" type="number" class="settings-input" value="1" min="1" max="5" />
                                </div>
                            </div>
                        </div>

                        <div class="settings-group">
                            <h3 class="settings-group-title">Communication</h3>
                            <div class="settings-field-list">
                                <div class="settings-field-row">
                                    <label for="settingAdminEmail">
                                        <strong>Admin notification email</strong>
                                        <span>Where organizer signups, new hikes, and flag alerts are sent.</span>
                                    </label>
                                    <input id="settingAdminEmail" type="email" class="settings-input" placeholder="admin@hikejordan.com" />
                                </div>
                                <div class="settings-field-row">
                                    <label for="settingSupportWa">
                                        <strong>Support WhatsApp number</strong>
                                        <span>Shown to visitors who need help. Include country code, e.g. +962791234567.</span>
                                    </label>
                                    <input id="settingSupportWa" type="tel" class="settings-input" placeholder="+962791234567" />
                                </div>
                            </div>
                        </div>

                        <div class="settings-group">
                            <h3 class="settings-group-title">Announcement banner</h3>
                            <div class="settings-field-list">
                                <div class="settings-field-row settings-field-row--wide">
                                    <label for="settingBanner">
                                        <strong>Banner message</strong>
                                        <span>Displayed at the top of every page when the banner is enabled.</span>
                                    </label>
                                    <input id="settingBanner" type="text" class="settings-input" placeholder="e.g. New hike season starts July 1 — check out the latest trips!" maxlength="200" />
                                </div>
                                <label class="settings-toggle-row">
                                    <div class="toggle-info">
                                        <strong>Show announcement banner</strong>
                                        <span>Enable to display the message above on all pages.</span>
                                    </div>
                                    <input type="checkbox" class="settings-toggle" />
                                </label>
                            </div>
                        </div>

                    </div>
                </section>
            </div>
        </div>
    </div>
</section>
